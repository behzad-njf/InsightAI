# =============================================================================
# InsightAI — environment template
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# --- Application ---
INSIGHTAI_ENV=development
INSIGHTAI_DEBUG=true
INSIGHTAI_LOG_LEVEL=INFO
INSIGHTAI_LOG_FORMAT=console
# console | json

INSIGHTAI_API_HOST=0.0.0.0
INSIGHTAI_API_PORT=8000
INSIGHTAI_API_RELOAD=true

# --- LLM provider: groq | openai ---
INSIGHTAI_LLM_PROVIDER=groq

# Groq Cloud (primary) — https://console.groq.com/
GROQ_API_KEY=
# Legacy alias supported by loaders:
GROK_API_KEY=

INSIGHTAI_GROQ_MODEL=llama-3.3-70b-versatile
INSIGHTAI_GROQ_TIMEOUT_SECONDS=60
INSIGHTAI_GROQ_MAX_RETRIES=2

# OpenAI (secondary)
OPENAI_API_KEY=
INSIGHTAI_OPENAI_MODEL=gpt-4o-mini
INSIGHTAI_OPENAI_TIMEOUT_SECONDS=60
INSIGHTAI_OPENAI_MAX_RETRIES=2

# Shared LLM settings
INSIGHTAI_LLM_MAX_TOKENS=4096
INSIGHTAI_LLM_TEMPERATURE=0.1

# --- AI framework: llamaindex | langchain (langchain = stub in Phase 1) ---
INSIGHTAI_AI_FRAMEWORK=llamaindex

# --- Database (multi-dialect) ---
# Kind: mssql | postgresql | sqlite
INSIGHTAI_DATABASE_KIND=mssql

# Full SQLAlchemy URL (password must be URL-safe, or use DB_* vars below)
# MSSQL example (ODBC Driver 17). Passwords with @ # & etc. break raw URLs — prefer DB_*.
# INSIGHTAI_DATABASE_READONLY_URL=mssql+pyodbc://sa:URL_ENCODED_PASS@localhost:1433/your_database?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

# Recommended for Docker MSSQL + sa password in .env (auto-encoded):
# INSIGHTAI_DATABASE_KIND=mssql
# DB_READONLY_USER=sa
# DB_READONLY_PASSWORD=your_password_here
# DB_HOST=localhost          # API on host, MSSQL published on 1433
# DB_HOST=host.docker.internal   # API inside docker compose, MSSQL on host
# DB_HOST=mssql              # MSSQL as a compose service on the same network
# DB_PORT=1433
# DB_NAME=your_database

# PostgreSQL example:
# INSIGHTAI_DATABASE_URL=postgresql+psycopg2://insightai:insightai@localhost:5432/insightai
# INSIGHTAI_DATABASE_READONLY_URL=postgresql+psycopg2://insightai_readonly:insightai@localhost:5432/insightai

# SQLite (local tests):
# INSIGHTAI_DATABASE_KIND=sqlite
# INSIGHTAI_DATABASE_READONLY_URL=sqlite:///./data/insightai_readonly.db

# Optional Phase 5.5 MSSQL integration tests (pytest -m mssql):
# INSIGHTAI_MSSQL_INTEGRATION_URL=mssql+pyodbc://readonly:pass@host:1433/your_database?driver=ODBC+Driver+17+for+SQL+Server

# MSSQL building blocks (used if URL not set — passwords auto URL-encoded)
DB_HOST=localhost
DB_PORT=1433
DB_NAME=your_database
DB_USER=
DB_PASSWORD=
DB_READONLY_USER=
DB_READONLY_PASSWORD=
DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# --- SQL execution limits (Phase 5 — applied by executor + RunQueryUseCase) ---
INSIGHTAI_SQL_MAX_ROWS=1000
# Per-query timeout for read-only SQL (seconds). Increase for heavy analytics queries.
INSIGHTAI_SQL_QUERY_TIMEOUT_SECONDS=120
INSIGHTAI_SQL_ENFORCE_READONLY=true

# --- Answer generation (Phase 6) ---
INSIGHTAI_ANSWER_MAX_PROMPT_ROWS=50

# --- Chat API (Phase 7) ---
INSIGHTAI_CHAT_MAX_QUESTION_LENGTH=4000
# SSE streaming: POST /api/v1/chat/stream (status → token → done)
INSIGHTAI_CHAT_STREAMING_ENABLED=true

# --- API authentication (Phase 7.4) ---
# Development: none | Production: api_key or jwt (enforced by settings validator)
INSIGHTAI_API_AUTH_MODE=none
# Comma-separated keys when mode=api_key
INSIGHTAI_API_KEYS=
INSIGHTAI_JWT_SECRET=
INSIGHTAI_JWT_ALGORITHM=HS256
# INSIGHTAI_JWT_AUDIENCE=
# INSIGHTAI_JWT_ISSUER=

# --- Rate limiting (Phase 7.5) ---
# Required when INSIGHTAI_ENV=production
INSIGHTAI_RATE_LIMIT_ENABLED=false
INSIGHTAI_RATE_LIMIT_REQUESTS=60
INSIGHTAI_RATE_LIMIT_WINDOW_SECONDS=60
INSIGHTAI_RATE_LIMIT_STORE=memory
# INSIGHTAI_RATE_LIMIT_TRUST_FORWARDED_FOR=false
# Session store: memory (default) | redis (requires: pip install insightai[redis])
INSIGHTAI_CHAT_SESSION_STORE=memory
INSIGHTAI_CHAT_SESSION_TTL_SECONDS=604800
INSIGHTAI_CHAT_SESSION_MAX_MESSAGES=200

# --- Observability (Phase 8) ---
INSIGHTAI_OBSERVABILITY_AUDIT_ENABLED=true
# Off by default — enable only with a PII-safe logging policy
INSIGHTAI_OBSERVABILITY_LOG_SQL=false
INSIGHTAI_OBSERVABILITY_LOG_QUESTION=false
INSIGHTAI_OBSERVABILITY_LLM_USAGE_ENABLED=true
# OpenTelemetry (pip install insightai[otel])
INSIGHTAI_OBSERVABILITY_TRACING_ENABLED=false
# INSIGHTAI_OBSERVABILITY_OTLP_ENDPOINT=http://localhost:4318/v1/traces
INSIGHTAI_OBSERVABILITY_SERVICE_NAME=insightai
# Prometheus scrape endpoint GET /metrics (pip install insightai[prometheus])
INSIGHTAI_OBSERVABILITY_METRICS_ENABLED=false

# --- Redis & cache (Phase 9) — baselines: docs/PERFORMANCE.md ---
INSIGHTAI_REDIS_URL=redis://localhost:6379/0
# Application cache (schema/query layers in 9.2+; requires insightai[redis] for redis store)
INSIGHTAI_CACHE_ENABLED=false
INSIGHTAI_CACHE_STORE=memory
INSIGHTAI_CACHE_DEFAULT_TTL_SECONDS=300
# INSIGHTAI_CACHE_KEY_PREFIX=insightai:cache:
# Schema context cache (Phase 9.2; active when CACHE_ENABLED=true)
INSIGHTAI_CACHE_SCHEMA_CONTEXT_ENABLED=true
# INSIGHTAI_CACHE_SCHEMA_CONTEXT_TTL_SECONDS=
# INSIGHTAI_CACHE_SCHEMA_CONTEXT_SCOPE_USER=false
# Query result cache (Phase 9.3; active when CACHE_ENABLED=true)
INSIGHTAI_CACHE_QUERY_RESULTS_ENABLED=true
INSIGHTAI_CACHE_QUERY_RESULTS_TTL_SECONDS=120
INSIGHTAI_CACHE_QUERY_RESULTS_SCOPE_USER=true

# --- Knowledge folder (business docs: policies, help, security) ---
# Place .md / .txt / .pdf files in Knowledge/ — synced into RAG on API startup when enabled.
INSIGHTAI_RAG_KNOWLEDGE_PATH=Knowledge
INSIGHTAI_RAG_SYNC_KNOWLEDGE_ON_STARTUP=true
# INSIGHTAI_RAG_SYNC_KNOWLEDGE_FORCE=false

# --- Embeddings / RAG (Phase 10) ---
# local = deterministic hash vectors (dev/tests); openai = text-embedding-3-small API
INSIGHTAI_EMBEDDING_PROVIDER=local
# INSIGHTAI_EMBEDDING_MODEL=text-embedding-3-small
# INSIGHTAI_EMBEDDING_LOCAL_MODEL=deterministic-hash-v1
# INSIGHTAI_EMBEDDING_DIMENSIONS=
# INSIGHTAI_EMBEDDING_MAX_BATCH_SIZE=100
# RAG ingest CLI (insightai-ingest) — see docs/RAG_INGEST.md
INSIGHTAI_RAG_CHUNK_SIZE=800
INSIGHTAI_RAG_CHUNK_OVERLAP=100
INSIGHTAI_RAG_DEFAULT_INDEX_PATH=data/rag_index/chunks.jsonl
# Vector store (insightai-rag-load) — see docs/RAG_INGEST.md
# memory = no Postgres required (dev); pgvector = production with insightai-rag-load
INSIGHTAI_RAG_VECTOR_BACKEND=memory
# INSIGHTAI_RAG_DATABASE_URL=postgresql+psycopg2://insightai:insightai@localhost:5432/insightai
# INSIGHTAI_RAG_VECTOR_TABLE=rag_document_chunks
# INSIGHTAI_RAG_VECTOR_INDEX_NAME=rag_document_chunks_embedding_hnsw_idx
# INSIGHTAI_RAG_VECTOR_UPSERT_BATCH_SIZE=100
# INSIGHTAI_RAG_SEARCH_TOP_K=5
# INSIGHTAI_RAG_SEARCH_MIN_SCORE=
# Hybrid router on POST /chat and POST /ask (Phase 10.4)
# Set true so chat can answer from Knowledge/ + SQL (requires vector backend below).
INSIGHTAI_RAG_ENABLED=true
# INSIGHTAI_RAG_ROUTER_MODE=heuristic
# INSIGHTAI_RAG_FALLBACK_TO_SQL_ON_EMPTY_INDEX=true
# LangChain tool-calling agent (requires pip install 'insightai[langchain]' and rag_enabled)
INSIGHTAI_LANGCHAIN_AGENT_ENABLED=false
# INSIGHTAI_LANGCHAIN_AGENT_MAX_ITERATIONS=8
# INSIGHTAI_AI_FRAMEWORK=langchain
# Chat: include_source_excerpts=true returns chunk text in sources[] (Phase 10.6)

# --- Schema ---
INSIGHTAI_SCHEMA_MARKDOWN_PATH=schema/database_schema.md
