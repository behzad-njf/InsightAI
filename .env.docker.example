# Docker Compose overrides — copy values into .env or use: docker compose --env-file .env
# Groq key is required for LLM endpoints.

GROQ_API_KEY=your_groq_key_here

INSIGHTAI_ENV=development
INSIGHTAI_DEBUG=false
INSIGHTAI_LOG_LEVEL=INFO
INSIGHTAI_LOG_FORMAT=json
INSIGHTAI_API_RELOAD=false

INSIGHTAI_LLM_PROVIDER=groq
INSIGHTAI_AI_FRAMEWORK=llamaindex

# Set by docker-compose.yml for the api service (reference only)
# INSIGHTAI_DATABASE_KIND=postgresql
# INSIGHTAI_DATABASE_READONLY_URL=postgresql+psycopg2://insightai_readonly:insightai_readonly@postgres:5432/insightai
# INSIGHTAI_REDIS_URL=redis://redis:6379/0
